{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "orchestrator": {
      "description": "Drives the full articulated-asset pipeline: runs deterministic scripts, invokes analyze/imagegen/placement/critic/joint_props subagents, and owns ordering, retries, and stop conditions.",
      "mode": "primary",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/orchestrator.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": {
          "*": "deny",
          "python *": "allow",
          "python3 *": "allow",
          "blender *": "allow",
          "cp *": "allow",
          "mkdir *": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "allow"
      }
    },
    "analyze": {
      "description": "Reads the source image and writes the minimal URDF parts list to parts.json.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/analyze.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": {"*": "deny", "*validate_json.py*": "allow"},
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },
    "joint_props": {
      "description": "After placement converges, writes joint_props.json (axes and limits) from the best assembly.json and source image.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/joint_props.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": {"*": "deny", "*validate_json.py*": "allow"},
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },
    "imagegen": {
      "description": "Generates one white-background image per prompt in prompts.json into component_images/.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/imagegen.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },
    "placement": {
      "description": "Generates an assembly.json IR for component GLBs from the source image and the previous critique.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/placement.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": {"*": "deny", "*validate_json.py*": "allow"},
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },
    "critic": {
      "description": "Critiques the rendered assembly against the source image, returning a score and structured feedback.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/critic.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": {"*": "deny", "*validate_json.py*": "allow"},
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    }
  }
}
