{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "analyze": {
      "description": "Reads the source image and writes the minimal URDF parts list to parts.json.",
      "mode": "primary",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/analyze.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": {"*": "deny", "*validate_json.py*": "allow"},
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },
    "imagegen": {
      "description": "Generates one white-background image per prompt in prompts.json into component_images/.",
      "mode": "primary",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/imagegen.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },
    "placement": {
      "description": "Generates a place_assets.json layout for component GLBs from the source image and the previous critique.",
      "mode": "primary",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/placement.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": {"*": "deny", "*validate_json.py*": "allow"},
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },
    "critic": {
      "description": "Plans render views and critiques the rendered assembly against the source image, returning a score and structured feedback.",
      "mode": "primary",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/critic.md}",
      "permission": {
        "edit": {"*": "deny", ".intermediate/**": "allow"},
        "bash": {"*": "deny", "*validate_json.py*": "allow"},
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    }
  }
}
