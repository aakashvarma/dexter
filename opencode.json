{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "orchestrator": {
      "description": "Drives the full articulated-asset pipeline: runs deterministic scripts, invokes analyze/critic subagents, and owns ordering, retries, and stop conditions.",
      "mode": "primary",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/orchestrator.md}",
      "permission": {
        "edit": {
          "*": "allow",
          ".opencode/**": "deny",
          "tool_scripts/**": "deny",
          "schemas/**": "deny",
          "configs/**": "deny",
          "docs/**": "deny",
          "input_images/**": "deny",
          "opencode.json": "deny",
          "AGENTS.md": "deny",
          "README.md": "deny",
          "requirements.txt": "deny",
          "pyproject.toml": "deny",
          ".gitignore": "deny"
        },
        "external_directory": {
          "*": "allow"
        },
        "bash": {
          "*": "deny",
          "python *": "allow",
          "python3 *": "allow",
          "blender *": "allow",
          "cp *": "allow",
          "mkdir *": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "allow"
      }
    },
    "analyze": {
      "description": "Reads the source image and writes the initial assembly layout to assembly.json.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/analyze.md}",
      "permission": {
        "edit": {
          "*": "allow",
          ".opencode/**": "deny",
          "tool_scripts/**": "deny",
          "schemas/**": "deny",
          "configs/**": "deny",
          "docs/**": "deny",
          "input_images/**": "deny",
          "opencode.json": "deny",
          "AGENTS.md": "deny",
          "README.md": "deny",
          "requirements.txt": "deny",
          "pyproject.toml": "deny",
          ".gitignore": "deny"
        },
        "external_directory": {
          "*": "allow"
        },
        "bash": {"*": "deny", "*common.py*": "allow"},
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },
    "critic": {
      "description": "Critiques the rendered assembly against the source image, returning a score and structured feedback.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/agents/critic.md}",
      "permission": {
        "edit": {
          "*": "allow",
          ".opencode/**": "deny",
          "tool_scripts/**": "deny",
          "schemas/**": "deny",
          "configs/**": "deny",
          "docs/**": "deny",
          "input_images/**": "deny",
          "opencode.json": "deny",
          "AGENTS.md": "deny",
          "README.md": "deny",
          "requirements.txt": "deny",
          "pyproject.toml": "deny",
          ".gitignore": "deny"
        },
        "external_directory": {
          "*": "allow"
        },
        "bash": {"*": "deny", "*common.py*": "allow"},
        "read": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    }
  }
}
